# spatial-machines Environment Variables
# Copy to .env and fill in your keys:
#   cp .env.example .env

# ── Required for core functionality ──────────────────────────────────

# Census API key (free: https://api.census.gov/data/key_signup.html)
# Used by: fetch_acs_data.py, fetch_census_population.py
# Not strictly required — works without it but may be rate-limited
CENSUS_API_KEY=

# ── Required for specific data sources ───────────────────────────────

# NOAA Climate Data Online token (free: https://www.ncdc.noaa.gov/cdo-web/token)
# Used by: fetch_noaa_climate.py
NOAA_API_TOKEN=

# FBI Crime Data API key (free: https://api.data.gov/signup/)
# Used by: fetch_fbi_crime.py
FBI_API_KEY=

# OpenWeatherMap API key (free tier: https://openweathermap.org/api)
# Used by: fetch_openweather.py
OPENWEATHER_API_KEY=

# ── Optional (increases rate limits) ─────────────────────────────────

# BLS API key (free: https://data.bls.gov/registrationEngine/)
# Used by: fetch_bls_employment.py — works without it, limited to 25 req/day
BLS_API_KEY=

# Socrata app token (free: sign up on any Socrata portal)
# Used by: fetch_socrata.py, fetch_cdc_places.py — works without it
SOCRATA_APP_TOKEN=

# HUD User API key (free: https://www.huduser.gov/hudapi/public/register)
# Used by: fetch_hud_data.py — may work without it for some endpoints
HUD_API_KEY=

# Mobility Database token (free: https://mobilitydatabase.org/)
# Used by: fetch_gtfs.py — only needed for feed search, not direct downloads
MOBILITY_DB_TOKEN=

# ── PostGIS (optional, for local OSM data) ───────────────────────────
# Only needed if you have a local PostGIS database with OSM data
# OSM_DB_HOST=localhost
# OSM_DB_PORT=5432
# OSM_DB_NAME=osmdb
# OSM_DB_USER=
# OSM_DB_PASSWORD=

# ── ArcGIS Online publishing (optional) ──────────────────────────────
# Only needed if publish_targets in your project brief includes "arcgis_online"
# or you run scripts/core/publish_arcgis_online.py directly.
# Install the arcgis package first:  pip install arcgis
# Free dev account:  https://developers.arcgis.com/
#
# AGOL_URL defaults to https://www.arcgis.com. Override for a custom org URL.
# Use AGOL_API_KEY, OR AGOL_USER + AGOL_PASSWORD — not all three.
# AGOL_URL=https://www.arcgis.com
# AGOL_USER=
# AGOL_PASSWORD=
# AGOL_API_KEY=
