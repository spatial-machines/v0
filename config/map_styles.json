  "inset_locator": {
    "_description": "Settings for the inset/locator map that shows geographic context ('you are here').",
    "enabled": true,
    "position": "upper left",
    "size": 0.22,
    "boundary_color": "#333333",
    "boundary_width": 0.8,
    "highlight_color": "#ff4444",
    "highlight_alpha": 0.3,
    "context_color": "#e8e8e8",
    "context_boundary": "#aaaaaa",
    "zoom_out_level": "state"
  },

  "typography": {
    "_description": "Editorial font hierarchy. Georgia for titles (authoritative serif), Gill Sans MT for body (humanist sans, Ordnance Survey lineage). Fallback chains ensure cross-platform rendering.",
    "title": {"family": "Georgia, Palatino Linotype, serif", "size": 15, "weight": "bold", "color": "#1a1a1a"},
    "subtitle": {"family": "Gill Sans MT, Gill Sans, Calibri, sans-serif", "size": 10, "weight": "normal", "color": "#555555"},
    "legend_title": {"family": "Gill Sans MT, Gill Sans, Calibri, sans-serif", "size": 10, "weight": "semibold", "color": "#333333"},
    "legend_label": {"family": "Gill Sans MT, Gill Sans, Calibri, sans-serif", "size": 9, "weight": "normal", "color": "#444444"},
    "attribution": {"family": "Gill Sans MT, Gill Sans, Calibri, sans-serif", "size": 7, "weight": "normal", "color": "#888888", "style": "italic"},
    "feature_label": {"family": "Gill Sans MT, Gill Sans, Calibri, sans-serif", "size": 7.5, "weight": "normal", "color": "#333333"},
    "annotation": {"family": "Gill Sans MT, Gill Sans, Calibri, sans-serif", "size": 8, "weight": "normal", "color": "#333333"}
  }
}
