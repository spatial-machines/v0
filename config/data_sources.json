{
  "version": 1,
  "description": "Registry of available data sources for spatial-machines. Each entry describes an API or download source, what it provides, and which fetch script handles it.",
  "sources": [
    {
      "id": "census-acs",
      "name": "Census American Community Survey",
      "provider": "U.S. Census Bureau",
      "script": "fetch_acs_data.py",
      "endpoint": "https://api.census.gov/data/{year}/acs/acs5",
      "auth": "optional",
      "auth_env_var": "CENSUS_API_KEY",
      "auth_signup": "https://api.census.gov/data/key_signup.html",
      "free": true,
      "returns": "CSV with demographic variables by tract/county/state",
      "geography": ["tract", "county", "state", "block group", "place"],
      "update_frequency": "annual",
      "category": "demographics"
    },
    {
      "id": "census-tiger",
      "name": "Census TIGER/Line Geometry",
      "provider": "U.S. Census Bureau",
      "script": "retrieve_tiger.py",
      "endpoint": "https://www2.census.gov/geo/tiger/TIGER{year}/TRACT/",
      "auth": "none",
      "free": true,
      "returns": "Shapefile ZIP with tract/county/state boundaries",
      "geography": ["tract", "county", "state", "block group"],
      "update_frequency": "annual",
      "category": "boundaries"
    },
    {
      "id": "census-decennial",
      "name": "Census Decennial Population",
      "provider": "U.S. Census Bureau",
      "script": "fetch_census_population.py",
      "endpoint": "https://api.census.gov/data/{year}/dec/pl",
      "auth": "none",
      "free": true,
      "returns": "CSV with population counts by tract",
      "geography": ["tract", "county", "state", "block group"],
      "update_frequency": "decennial",
      "category": "demographics"
    },
    {
      "id": "osm-overpass",
      "name": "OpenStreetMap (Overpass API)",
      "provider": "OpenStreetMap Foundation",
      "script": "fetch_poi.py",
      "endpoint": "https://overpass-api.de/api/interpreter",
      "auth": "none",
      "free": true,
      "returns": "GeoPackage with POI points (amenities, shops, services)",
      "geography": ["point", "bbox", "area"],
      "update_frequency": "real-time",
      "category": "points-of-interest"
    },
    {
      "id": "epa-ejscreen",
      "name": "EPA EJScreen",
      "provider": "U.S. Environmental Protection Agency",
      "script": "fetch_ejscreen.py",
      "endpoint": "https://ejscreen.epa.gov/mapper/ejscreenRESTbroker.aspx",
      "auth": "none",
      "free": true,
      "returns": "JSON with environmental justice indicators by location/buffer",
      "geography": ["point+buffer", "tract", "block group"],
      "update_frequency": "annual",
      "category": "environment"
    },
    {
      "id": "cdc-places",
      "name": "CDC PLACES",
      "provider": "Centers for Disease Control and Prevention",
      "script": "fetch_cdc_places.py",
      "endpoint": "https://data.cdc.gov/resource/swc5-untb.json",
      "auth": "optional",
      "auth_env_var": "SOCRATA_APP_TOKEN",
      "auth_signup": "https://data.cdc.gov/signup",
      "free": true,
      "returns": "JSON/CSV with health outcome estimates by tract/county/place",
      "geography": ["tract", "county", "place"],
      "update_frequency": "annual",
      "category": "health"
    },
    {
      "id": "fema-nfhl",
      "name": "FEMA National Flood Hazard Layer",
      "provider": "Federal Emergency Management Agency",
      "script": "fetch_fema_nfhl.py",
      "endpoint": "https://hazards.fema.gov/gis/nfhl/rest/services/public/NFHL/MapServer",
      "auth": "none",
      "free": true,
      "returns": "GeoJSON with flood zone polygons",
      "geography": ["county", "bbox"],
      "update_frequency": "continuous",
      "category": "hazards"
    },
    {
      "id": "usda-food-access",
      "name": "USDA Food Access Research Atlas",
      "provider": "U.S. Department of Agriculture",
      "script": "fetch_usda_food_access.py",
      "endpoint": "https://www.ers.usda.gov/data-products/food-access-research-atlas/",
      "auth": "none",
      "free": true,
      "returns": "CSV with food desert indicators by tract",
      "geography": ["tract"],
      "update_frequency": "periodic",
      "category": "food-access"
    },
    {
      "id": "hud-chas",
      "name": "HUD CHAS (Housing Needs)",
      "provider": "U.S. Department of Housing and Urban Development",
      "script": "fetch_hud_data.py",
      "endpoint": "https://www.huduser.gov/portal/datasets/cp.html",
      "auth": "optional",
      "auth_env_var": "HUD_API_KEY",
      "auth_signup": "https://www.huduser.gov/hudapi/public/register",
      "free": true,
      "returns": "CSV with housing cost burden, affordability, and needs data",
      "geography": ["tract", "county", "state"],
      "update_frequency": "periodic",
      "category": "housing"
    },
    {
      "id": "lehd-lodes",
      "name": "LEHD LODES (Origin-Destination Employment)",
      "provider": "U.S. Census Bureau",
      "script": "fetch_lehd_lodes.py",
      "endpoint": "https://lehd.ces.census.gov/data/lodes/LODES8/",
      "auth": "none",
      "free": true,
      "returns": "CSV with workplace/residential/OD employment counts by block",
      "geography": ["block", "tract (aggregated)"],
      "update_frequency": "annual",
      "category": "employment"
    },
    {
      "id": "noaa-climate",
      "name": "NOAA Climate Data (GHCN)",
      "provider": "National Oceanic and Atmospheric Administration",
      "script": "fetch_noaa_climate.py",
      "endpoint": "https://www.ncei.noaa.gov/cdo-web/api/v2/",
      "auth": "required",
      "auth_env_var": "NOAA_API_TOKEN",
      "auth_signup": "https://www.ncdc.noaa.gov/cdo-web/token",
      "free": true,
      "returns": "JSON/CSV with weather station observations (temp, precip, etc.)",
      "geography": ["station", "county", "state"],
      "update_frequency": "daily",
      "category": "climate"
    },
    {
      "id": "bls-employment",
      "name": "Bureau of Labor Statistics",
      "provider": "U.S. Department of Labor",
      "script": "fetch_bls_employment.py",
      "endpoint": "https://api.bls.gov/publicAPI/v2/timeseries/data/",
      "auth": "optional",
      "auth_env_var": "BLS_API_KEY",
      "auth_signup": "https://data.bls.gov/registrationEngine/",
      "free": true,
      "returns": "JSON with employment, unemployment, wage time series by area",
      "geography": ["county", "metro", "state"],
      "update_frequency": "monthly",
      "category": "employment"
    },
    {
      "id": "fbi-crime",
      "name": "FBI Crime Data Explorer",
      "provider": "Federal Bureau of Investigation",
      "script": "fetch_fbi_crime.py",
      "endpoint": "https://api.usa.gov/crime/fbi/sapi/",
      "auth": "required",
      "auth_env_var": "FBI_API_KEY",
      "auth_signup": "https://api.data.gov/signup/",
      "free": true,
      "returns": "JSON with crime statistics by agency/state/year",
      "geography": ["agency (ORI)", "state"],
      "update_frequency": "annual",
      "category": "public-safety"
    },
    {
      "id": "socrata-open-data",
      "name": "Socrata Open Data (generic)",
      "provider": "Various (cities, counties, states)",
      "script": "fetch_socrata.py",
      "endpoint": "https://{domain}/resource/{dataset_id}.json",
      "auth": "optional",
      "auth_env_var": "SOCRATA_APP_TOKEN",
      "free": true,
      "returns": "JSON/CSV from any Socrata-powered open data portal",
      "geography": ["varies"],
      "update_frequency": "varies",
      "category": "open-data"
    },
    {
      "id": "usgs-elevation",
      "name": "USGS National Map (Elevation/DEM)",
      "provider": "U.S. Geological Survey",
      "script": "fetch_usgs_elevation.py",
      "endpoint": "https://tnmaccess.nationalmap.gov/api/v1/products",
      "auth": "none",
      "free": true,
      "returns": "GeoTIFF DEM raster tiles",
      "geography": ["bbox", "state", "county"],
      "update_frequency": "periodic",
      "category": "terrain"
    },
    {
      "id": "gtfs-transit",
      "name": "GTFS Transit Feeds",
      "provider": "Transit agencies (via Mobility Database)",
      "script": "fetch_gtfs.py",
      "endpoint": "https://api.mobilitydatabase.org/v1/",
      "auth": "optional",
      "auth_env_var": "MOBILITY_DB_TOKEN",
      "auth_signup": "https://mobilitydatabase.org/",
      "free": true,
      "returns": "GTFS ZIP with routes, stops, schedules",
      "geography": ["agency service area"],
      "update_frequency": "varies by agency",
      "category": "transit"
    },
    {
      "id": "overture-maps",
      "name": "Overture Maps (Buildings, Places, Transport)",
      "provider": "Overture Maps Foundation",
      "script": "fetch_overture.py",
      "endpoint": "https://overturemaps-us-west-2.s3.amazonaws.com/release/",
      "auth": "none",
      "free": true,
      "returns": "GeoParquet with buildings, places, roads, land use",
      "geography": ["bbox", "global"],
      "update_frequency": "quarterly",
      "category": "base-data"
    },
    {
      "id": "openweather",
      "name": "OpenWeatherMap",
      "provider": "OpenWeather Ltd",
      "script": "fetch_openweather.py",
      "endpoint": "https://api.openweathermap.org/data/2.5/",
      "auth": "required",
      "auth_env_var": "OPENWEATHER_API_KEY",
      "auth_signup": "https://openweathermap.org/api",
      "free": "freemium (1000 calls/day free)",
      "returns": "JSON with current/forecast weather for any location",
      "geography": ["point (lat/lon)", "city name"],
      "update_frequency": "real-time",
      "category": "weather"
    },
    {
      "id": "local-file",
      "name": "Local File System",
      "provider": "User",
      "script": "retrieve_local.py",
      "endpoint": null,
      "auth": "none",
      "free": true,
      "returns": "Any supported format (GeoPackage, Shapefile, CSV, GeoJSON, Parquet)",
      "geography": ["any"],
      "update_frequency": "n/a",
      "category": "local"
    },
    {
      "id": "remote-url",
      "name": "Remote URL (any downloadable file)",
      "provider": "Any HTTP server",
      "script": "retrieve_remote.py",
      "endpoint": null,
      "auth": "none",
      "free": true,
      "returns": "Any downloadable file (CSV, GeoJSON, ZIP, GeoPackage, Parquet)",
      "geography": ["any"],
      "update_frequency": "n/a",
      "category": "remote"
    }
  ]
}
